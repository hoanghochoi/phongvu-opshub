    {
      "parameters": {
        "jsCode": "const items = $input.all();\n\nconst out = items.map(it => {\n  const r = it.json;\n\n  const d = new Date(r.createdAt);\n  const date = `${String(d.getDate()).padStart(2, '0')}/${\n               String(d.getMonth() + 1).padStart(2, '0')}/${\n               d.getFullYear()}`;\n\n  return {\n    receipt: r.receipt,\n    date,\n    user: r.user,\n  };\n});\n\nreturn out;\n"
      },
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [
        672,
        224
      ],
      "id": "98becc5a-3ceb-48b1-992d-54ec405d1420",
      "name": "genListAllReceipt"
    },
    {
      "parameters": {
        "jsCode": "const items = $input.all();\n\nconst out = items.map(it => {\n  const r = it.json;\n\n  const d = new Date(r.createdAt);\n  const date = `${String(d.getDate()).padStart(2, '0')}/${\n               String(d.getMonth() + 1).padStart(2, '0')}/${\n               d.getFullYear()}`;\n\n  return {\n    receipt: r.receipt,\n    date,\n    user: r.user,\n  };\n});\n\nreturn out;\n"
      },
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [
        448,
        448
      ],
      "id": "47e6508f-ab1a-44c5-993a-466ac01e5682",
      "name": "genListSearchReceipt"
    },
    {
      "parameters": {
        "jsCode": "const fs = require('fs');\nconst path = require('path');\n\n\nconst receipt = $input.first().json.receipt;\nconst user = $input.first().json.user;\n\nif (!receipt) {\n  throw new Error(\"Missing 'receipt' in webhook body\");\n}\nif (!user) {\n  throw new Error(\"Missing 'user' in webhook body\");\n}\n\n// Thư mục chứa ảnh: /home/ubuntu/n8n/app_images\nconst baseDir = '/data/app_images';\nconst dir = path.join(baseDir, receipt);\n\n// Kiểm tra tồn tại\nif (!fs.existsSync(dir)) {\n  throw new Error(`Folder not found: ${dir}`);\n}\n\n// Lấy danh sách file ảnh\nlet files = fs.readdirSync(dir)\n  .filter(f => /\\.(jpe?g|png|gif|webp)$/i.test(f))\n  .sort(); // sắp xếp cho ổn định\n\n// Build URLs ảnh\nconst baseUrl = 'https://img.hoanghochoi.com';\nconst images = files.map(f => `${baseUrl}/${receipt}/${f}`);\n\n// Lấy ngày folder được tạo (ưu tiên birthtime, fallback mtime)\nconst stats = fs.statSync(dir);\nconst dt = (stats.birthtimeMs && stats.birthtimeMs > 0)\n  ? stats.birthtime\n  : stats.mtime;\n\n// Format dd/MM/yyyy\nconst d = dt;\nconst date =\n  `${String(d.getDate()).padStart(2, '0')}/` +\n  `${String(d.getMonth() + 1).padStart(2, '0')}/` +\n  `${d.getFullYear()}`;\n\n// Trả về 1 item duy nhất\nreturn [\n  {\n    json: {\n      receipt,\n      user,\n      date,\n      images,\n    },\n  },\n];\n"
      },
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [
