      "notesInFlow": true,
      "notes": "/bhsc-get"
    },
    {
      "parameters": {
        "jsCode": "// Lấy item duy nhất từ Webhook\nconst item = $input.first();\n\n// Body có thể là item.json.body hoặc item.json tùy config Webhook\nconst body = item.json.body ?? item.json;\n\nconst email = body.user;\nconst receipt = body.receipt;\n\nconst binaries = item.binary || {};\n\nconst out = [];\nlet idx = 0;\n\nfor (const [key, bin] of Object.entries(binaries)) {\n  // chỉ lấy các field bắt đầu bằng 'image'\n  if (!key.startsWith('image')) continue;\n\n  out.push({\n    json: {\n      email,\n      receipt,\n      index: idx,\n    },\n    binary: {\n      data: bin, // chuẩn hóa vào property 'data'\n    },\n  });\n\n  idx++;\n}\n\nreturn out;\n"
      },
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [
        224,
        0
      ],
      "id": "d96a22f9-26ed-4ef6-9f2c-24a828e9cc1f",
      "name": "SplitBinary"
    },
    {
      "parameters": {
        "jsCode": "const fs = require('fs');\nconst path = require('path');\n\nconst items = $input.all();\nif (!items.length) {\n  throw new Error('No items received');\n}\n\n// Body từ item đầu (node save)\nconst body = items[0].json.body || items[0].json || {};\nconst email = body.email;\nconst receipt = body.receipt;\n\nif (!email) throw new Error(\"Missing 'email' in body\");\nif (!receipt) throw new Error(\"Missing 'receipt' in body\");\n\n// Lưu vào host: /data/app_images/<receipt>/\nconst baseDir = '/data/app_images';\nconst receiptDir = path.join(baseDir, receipt);\n\nif (!fs.existsSync(receiptDir)) {\n  fs.mkdirSync(receiptDir, { recursive: true });\n}\n\n// Helper lấy đuôi từ fileName image_0.jpg -> jpg\nconst getExtFromName = (name) => {\n  if (!name) return '';\n  const parts = String(name).split('.');\n  if (parts.length < 2) return '';\n  return parts.pop().toLowerCase();\n};\n\nconst allowed = ['jpg', 'jpeg', 'png', 'gif', 'webp'];\n\nconst links = [];\n\nfor (let i = 0; i < items.length; i++) {\n  const meta = items[i].binary?.data;\n  if (!meta) {\n    throw new Error(`Item ${i} missing binary.data`);\n  }\n\n  // Lấy đúng buffer từ n8n\n  const buffer = await this.helpers.getBinaryDataBuffer(i, 'data');\n\n  let ext = getExtFromName(meta.fileName);\n  if (!ext || !allowed.includes(ext)) {\n    ext = 'jpg';\n  }\n\n  const filename = `${receipt}-${i}.${ext}`;\n  const filePath = path.join(receiptDir, filename);\n\n  fs.writeFileSync(filePath, buffer);\n\n  links.push(`/app_images/${receipt}/${filename}`);\n}\n\nreturn [\n  {\n    json: {\n      email,\n      receipt,\n      links,\n    },\n  },\n];\n"
      },
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [
        448,
        0
      ],
      "id": "6c03c157-a630-410f-8cac-fffcc55e05cf",
      "name": "SaveFiles"
    },
    {
      "parameters": {
        "jsCode": "// Lấy item duy nhất từ node trước\nconst item = $input.first();\n\nconst email = item.json.email;\nconst receipt = item.json.receipt;\n// links đang là array path tương đối\nconst links = item.json.links || [];\n\n// Nếu muốn convert thành full URL luôn:\nconst baseUrl = 'https://n8n.hoanghochoi.com';\nconst fullLinks = links.map(p => p.startsWith('/') ? baseUrl + p : p);\n\nreturn [\n  {\n    json: {\n      email,\n      receipt,\n      links: fullLinks,             // mảng URL đầy đủ\n      links_str: fullLinks.join(';') // dạng string nếu cần\n    }\n  }\n];\n"
      },
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [
