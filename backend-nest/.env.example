PORT=3000
NODE_ENV=development
DATABASE_URL=postgresql://opshub_user:opshub_password@localhost:5432/opshub_db
JWT_SECRET=replace-with-a-long-random-secret
PUBLIC_BASE_URL=http://localhost:3000

# Email verification and password reset codes.
# For Gmail, use an app password for SMTP_USER and a verified Send mail as alias for SMTP_FROM.
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=hoanghochoi1618@gmail.com
SMTP_PASS=replace-with-gmail-app-password
SMTP_FROM=admin@hoanghochoi.com
# Optional but recommended: dedicated AES-GCM secret for encrypted VietinBank MAP credentials.
MAP_VIETIN_CREDENTIAL_SECRET=replace-with-another-long-random-secret
# Optional VietinBank MAP endpoint overrides. Defaults match the observed MAP web app.
# MAP_VIETIN_CLIENT_ID=c4a59ac3630f6d8f1abe722eac7052b5
# MAP_VIETIN_SIGNATURE_KEY=replace-with-observed-signature-key
# MAP_VIETIN_NO_AUTH_BASE_URL=https://map.vietinbank.vn/vtb/public/map/api/ma/no-auth
# MAP_VIETIN_TRANSACTION_BASE_URL=https://map.vietinbank.vn/vtb/public/map/api/rpt-txnmng/api
# MAP_VIETIN_LOGIN_IP=118.70.124.48
# Optional global MAP account. When username/password are set, background sync
# uses this account as the primary source and maps virtualAccount to Store.transferAccountNumber.
# Per-store MAP credentials remain a fallback when global sync is disabled or not configured.
# MAP_VIETIN_GLOBAL_USERNAME=global-map-user
# MAP_VIETIN_GLOBAL_PASSWORD=global-map-password
# MAP_VIETIN_GLOBAL_SYNC_ENABLED=true
# MAP_VIETIN_GLOBAL_SYNC_MAX_PAGES=10
# MAP_VIETIN_GLOBAL_SESSION_TTL_SECONDS=600
# Overall provider request timeout and maximum JSON response body.
BANK_PROVIDER_TIMEOUT_MS=30000
BANK_PROVIDER_RESPONSE_MAX_BYTES=10485760
# Optional VietinBank eFAST account-detail sync source. Fill only in local/server .env.
# Keep disabled unless this server should pull eFAST account/detail history.
VIETIN_EFAST_SYNC_ENABLED=false
# VIETIN_EFAST_USERNAME=your-efast-login-account
# VIETIN_EFAST_PASSWORD=replace-with-efast-password
# History source accounts only; eFAST rows map to stores through row pmtId.
# VIETIN_EFAST_BANK_ACCOUNTS=bank-account-number-1,bank-account-number-2
# Optional when the eFAST login account has multiple enterprises/cifno choices.
# VIETIN_EFAST_CIFNO=enterprise-cifno
# Optional stable device id for eFAST login; defaults to a deterministic OpsHub hash.
# VIETIN_EFAST_DEVICE_ID=server-device-id
# VIETIN_EFAST_BASE_URL=https://efast.vietinbank.vn
# VIETIN_EFAST_ACCOUNT_DETAIL_PATH=/account/detail
# VIETIN_EFAST_PAGE_SIZE=150
# VIETIN_EFAST_SYNC_MAX_PAGES=1
# VIETIN_EFAST_SESSION_TTL_SECONDS=600

# Optional override. Defaults to ../data/email_domain.txt from backend-nest/.
EMAIL_DOMAIN_FILE=../data/email_domain.txt
ALLOWED_ORIGINS=http://localhost:3000,http://localhost:8080

# ERP order lookup for sales reports.
# Fill ERP_USERNAME and ERP_PASSWORD on the server; never commit real values.
ERP_USERNAME=your-erp-username
ERP_PASSWORD=replace-with-erp-password
# Optional: use a temporary bearer token for smoke testing instead of username/password.
# ERP_ACCESS_TOKEN=replace-with-temporary-erp-token
ERP_IDENTITY_BASE_URL=https://identity.tekoapis.com
ERP_OAUTH_BASE_URL=https://oauth-merchant.phongvu.vn
ERP_STAFF_BFF_BASE_URL=https://staff-bff.tekoapis.com
ERP_LISTING_BASE_URL=https://listing.tekoapis.com
ERP_CLIENT_ID=04409baea81b46e1a53e64efe0de16a5
ERP_REDIRECT_URI=https://erp.phongvu.vn
ERP_LISTING_CHANNEL=pv_showroom
ERP_TOKEN_TTL_SAFETY_SECONDS=60
ERP_ORDER_TIMEOUT_MS=10000
# ERP order cockpit cache for sales reports.
# Defaults mirror the current staff-bff URL shared by ops; change without code when ERP ownership changes.
ERP_ORDER_LIST_SELLER_ID=1
ERP_ORDER_LIST_PLATFORM_ID=3
ERP_ORDER_LIST_SORT=-createdAt
ERP_ORDER_CACHE_SYNC_ENABLED=true
ERP_ORDER_CACHE_SYNC_ON_STARTUP=true
ERP_ORDER_CACHE_SYNC_LIMIT=50
ERP_ORDER_CACHE_SYNC_LOOKBACK_DAYS=1
# Re-check pending and recent completed orders every 5 minutes. Background quota:
# pending <= 5 checks/Vietnam day; completed <= 1 check/Vietnam day and <= 10 sale days old.
ERP_ORDER_STATUS_SYNC_ENABLED=true
ERP_ORDER_STATUS_CACHE_SYNC_ENABLED=true
ERP_ORDER_STATUS_CACHE_LOOKBACK_DAYS=2
ERP_ORDER_STATUS_SYNC_BATCH_SIZE=80
ERP_ORDER_STATUS_SYNC_CONCURRENCY=2
ERP_ORDER_STATUS_SYNC_STORE_LIMIT=20
ERP_ORDER_STATUS_PENDING_RECHECK_MINUTES=5
# Home near-realtime projection. Keep the legacy fallback off after projection
# parity is proven. Enable the checkpointed ERP backfill for the first rollout;
# a completed checkpoint makes later restarts a no-op.
HOME_SUMMARY_PROJECTION_ENABLED=true
HOME_SUMMARY_PROJECTION_WORKER_ENABLED=true
HOME_SUMMARY_LEGACY_SYNC_FALLBACK_ENABLED=false
HOME_SUMMARY_ERP_BACKFILL_ENABLED=false
HOME_SUMMARY_ERP_BACKFILL_DAYS=90
# Optional override. Defaults to ../data/categories.csv from backend-nest/.
# SALES_REPORT_CATEGORIES_CSV=../data/categories.csv
# Optional outbound BigQuery sync for sales-report data. Looker Studio should
# connect to these BigQuery tables instead of calling OpsHub runtime APIs.
SALES_REPORT_BIGQUERY_SYNC_ENABLED=false
SALES_REPORT_BIGQUERY_SYNC_ON_STARTUP=false
# SALES_REPORT_BIGQUERY_PROJECT_ID=your-gcp-project
# SALES_REPORT_BIGQUERY_DATASET_ID=opshub_reporting
# SALES_REPORT_BIGQUERY_KEY_FILE=/data/import/bigquery-service-account.json
# SALES_REPORT_BIGQUERY_TABLE_PREFIX=opshub_sales_report
# SALES_REPORT_BIGQUERY_REPORT_TABLE_ID=opshub_sales_report_reports
# SALES_REPORT_BIGQUERY_REVENUE_TABLE_ID=opshub_sales_report_revenue_by_store
# SALES_REPORT_BIGQUERY_ITEM_TABLE_ID=opshub_sales_report_items
# SALES_REPORT_BIGQUERY_PAYMENT_TABLE_ID=opshub_sales_report_payments
# SALES_REPORT_BIGQUERY_MAX_ROWS=100000

REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=replace-with-a-long-random-secret
# REDIS_USERNAME=opshub-api
# REDIS_TLS=false
# REDIS_TLS_REJECT_UNAUTHORIZED=true
# REDIS_TLS_SERVERNAME=redis.internal
# REDIS_TLS_CA_FILE=/run/secrets/redis-ca.pem

DATA_SYNC_SOURCE=local

# FIFO reads/writes use the OpsHub database through DATABASE_URL.
# The FIFO cache table uses BigQuery canonical column names plus opshub_* metadata.
OPSHUB_FIFO_INVENTORY_TABLE=fifo_inventory
FIFO_DATE_TOLERANCE_DAYS=20
INVENTORY_UPLOAD_MAX_BYTES=20971520

# FIFO BigQuery sync runs daily at 08:00 Asia/Ho_Chi_Minh when these are set.
# BIGQUERY_FIFO_DATASET_ID / BIGQUERY_FIFO_TABLE_ID can override the generic
# dataset/table for FIFO only.
# BIGQUERY_PROJECT_ID=your-gcp-project
# Keep service-account JSON outside the repo checkout.
# BIGQUERY_KEY_FILE=/data/import/bigquery-service-account.json
# BIGQUERY_DATASET_ID=your_inventory_dataset
# BIGQUERY_TABLE_ID=your_inventory_table
# BIGQUERY_FIFO_DATASET_ID=your_fifo_inventory_dataset
# BIGQUERY_FIFO_TABLE_ID=your_fifo_inventory_table
# Optional aliases when sharing the price_watchdog BigQuery env file.
# PRICE_WATCHDOG_BIGQUERY_PROJECT_ID=your-gcp-project
# PRICE_WATCHDOG_BIGQUERY_DATASET=Inventory
# PRICE_WATCHDOG_BIGQUERY_TABLE=inv_seri_1
# GOOGLE_APPLICATION_CREDENTIALS=/data/import/bigquery-service-account.json
# BIGQUERY_USER_DATASET_ID=your_user_dataset
# BIGQUERY_USER_TABLE_ID=your_user_table

UPLOAD_BASE_DIR=/data/app_images
IMAGE_BASE_URL=https://img.example.com
PRIVATE_MEDIA_BASE_DIR=/data/private-media
PRIVATE_MEDIA_PUBLIC_BASE_URL=http://localhost:3000
PRIVATE_UPLOAD_TEMP_DIR=/tmp/opshub-private-uploads
UPLOAD_AGGREGATE_MAX_BYTES=31457280
PRIVATE_MEDIA_MAX_PIXELS=24000000
UPLOAD_MAX_BYTES=10485760
AVATAR_UPLOAD_MAX_BYTES=2097152
REQUEST_BODY_LIMIT=1mb

# Payment notification audio. Production defaults target the Piper sidecar.
# TTS_SERVICE_URL=http://172.20.0.1:18081
TTS_VOICE_ID=piper:vi-vais1000
TTS_SPEED=0.90
TTS_PITCH=1.00
TTS_TIMEOUT_MS=20000
TTS_RESPONSE_MAX_BYTES=20971520
PAYMENT_TTS_CONCURRENCY=2
PAYMENT_SPEAKER_STREAMING_ENABLED=true
PAYMENT_STREAM_EVENT_REPEAT_COUNT=3
PAYMENT_STREAM_EVENT_REPEAT_GAP_MS=1000
PAYMENT_STREAM_PENDING_RECOVERY_WINDOW_SECONDS=30
PAYMENT_CUE_GAIN=0.80
# Optional trial: TTS only the dynamic amount and join a fixed prefix WAV at playback.
# Requires PAYMENT_PREFIX_WAV_PATH to point to a real PCM 16-bit WAV saying "Phong Vũ đã nhận:".
# PAYMENT_CUE_PREFIX_WAV_PATH may point to a prejoined cue+prefix WAV generated with PAYMENT_CUE_GAIN.
PAYMENT_TTS_AUDIO_MODE=amount_only_with_prefix
PAYMENT_PREFIX_WAV_PATH=/data/import/payment-prefix.wav
PAYMENT_CUE_PREFIX_WAV_PATH=/data/import/payment-cue-prefix.wav
PAYMENT_AMOUNT_AUDIO_CACHE_RETENTION_DAYS=90

# VietQR transfer QR generation. Bank BIN is the Napas/VietQR bank code.
VIETQR_BANK_BIN=970436
VIETQR_ACCOUNT_NUMBER=123456789
VIETQR_ACCOUNT_NAME=PHONG VU
VIETQR_MERCHANT_CITY=HO CHI MINH
# Required only for /vietqr/n8n and /vietqr/n8n/image. Send it through
# x-opshub-vietqr-key or Authorization: Bearer <key> from n8n.
# VIETQR_EXTERNAL_API_KEY=change-this-n8n-vietqr-key
# Optional image logo override. Defaults to the repo app icon when available.
# VIETQR_LOGO_PATH=/data/import/app_icon_master.png
# Optional ACareTek VietQR logo override. Defaults to repo assets/icon/acare_logo.png.
# VIETQR_ACARE_LOGO_PATH=/data/import/acare_logo.png
