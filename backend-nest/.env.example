PORT=3000
NODE_ENV=development
DATABASE_URL=postgresql://opshub_user:opshub_password@localhost:5432/opshub_db
JWT_SECRET=replace-with-a-long-random-secret
PUBLIC_BASE_URL=http://localhost:3000

# Email verification and password reset codes.
# For Gmail, use an app password for SMTP_USER and a verified Send mail as alias for SMTP_FROM.
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=hoanghochoi1618@gmail.com
SMTP_PASS=replace-with-gmail-app-password
SMTP_FROM=admin@hoanghochoi.com
# Optional but recommended: dedicated AES-GCM secret for encrypted VietinBank MAP credentials.
MAP_VIETIN_CREDENTIAL_SECRET=replace-with-another-long-random-secret
# Optional VietinBank MAP endpoint overrides. Defaults match the observed MAP web app.
# MAP_VIETIN_CLIENT_ID=c4a59ac3630f6d8f1abe722eac7052b5
# MAP_VIETIN_SIGNATURE_KEY=replace-with-observed-signature-key
# MAP_VIETIN_NO_AUTH_BASE_URL=https://map.vietinbank.vn/vtb/public/map/api/ma/no-auth
# MAP_VIETIN_TRANSACTION_BASE_URL=https://map.vietinbank.vn/vtb/public/map/api/rpt-txnmng/api
# MAP_VIETIN_LOGIN_IP=118.70.124.48
# Optional global MAP account. When username/password are set, background sync
# uses this account as the primary source and maps virtualAccount to Store.transferAccountNumber.
# Per-store MAP credentials remain a fallback when global sync is disabled or not configured.
# MAP_VIETIN_GLOBAL_USERNAME=global-map-user
# MAP_VIETIN_GLOBAL_PASSWORD=global-map-password
# MAP_VIETIN_GLOBAL_SYNC_ENABLED=true
# MAP_VIETIN_GLOBAL_SYNC_MAX_PAGES=10
# MAP_VIETIN_GLOBAL_SESSION_TTL_SECONDS=600

# Optional override. Defaults to ../data/email_domain.txt from backend-nest/.
EMAIL_DOMAIN_FILE=../data/email_domain.txt
ALLOWED_ORIGINS=http://localhost:3000,http://localhost:8080

REDIS_HOST=localhost
REDIS_PORT=6379

DATA_SYNC_SOURCE=local

# FIFO reads/writes use the OpsHub database through DATABASE_URL.
# The FIFO cache table uses BigQuery canonical column names plus opshub_* metadata.
OPSHUB_FIFO_INVENTORY_TABLE=fifo_inventory
FIFO_DATE_TOLERANCE_DAYS=20
INVENTORY_UPLOAD_MAX_BYTES=20971520

# FIFO BigQuery sync runs daily at 08:00 Asia/Ho_Chi_Minh when these are set.
# BIGQUERY_FIFO_DATASET_ID / BIGQUERY_FIFO_TABLE_ID can override the generic
# dataset/table for FIFO only.
# BIGQUERY_PROJECT_ID=your-gcp-project
# Keep service-account JSON outside the repo checkout.
# BIGQUERY_KEY_FILE=/data/import/bigquery-service-account.json
# BIGQUERY_DATASET_ID=your_inventory_dataset
# BIGQUERY_TABLE_ID=your_inventory_table
# BIGQUERY_FIFO_DATASET_ID=your_fifo_inventory_dataset
# BIGQUERY_FIFO_TABLE_ID=your_fifo_inventory_table
# Optional aliases when sharing the price_watchdog BigQuery env file.
# PRICE_WATCHDOG_BIGQUERY_PROJECT_ID=your-gcp-project
# PRICE_WATCHDOG_BIGQUERY_DATASET=Inventory
# PRICE_WATCHDOG_BIGQUERY_TABLE=inv_seri_1
# GOOGLE_APPLICATION_CREDENTIALS=/data/import/bigquery-service-account.json
# BIGQUERY_USER_DATASET_ID=your_user_dataset
# BIGQUERY_USER_TABLE_ID=your_user_table

UPLOAD_BASE_DIR=/data/app_images
IMAGE_BASE_URL=https://img.example.com
UPLOAD_MAX_BYTES=5242880
REQUEST_BODY_LIMIT=1mb

# Payment notification audio. Production defaults target the Piper sidecar.
# TTS_SERVICE_URL=http://172.20.0.1:18081
TTS_VOICE_ID=piper:vi-vais1000
TTS_SPEED=0.90
TTS_PITCH=1.00
TTS_TIMEOUT_MS=20000

# VietQR transfer QR generation. Bank BIN is the Napas/VietQR bank code.
VIETQR_BANK_BIN=970436
VIETQR_ACCOUNT_NUMBER=123456789
VIETQR_ACCOUNT_NAME=PHONG VU
VIETQR_MERCHANT_CITY=HO CHI MINH
# Required only for /vietqr/n8n and /vietqr/n8n/image. Send it through
# x-opshub-vietqr-key or Authorization: Bearer <key> from n8n.
# VIETQR_EXTERNAL_API_KEY=change-this-n8n-vietqr-key
# Optional image logo override. Defaults to the repo app icon when available.
# VIETQR_LOGO_PATH=/data/import/app_icon_master.png
# Optional ACareTek VietQR logo override. Defaults to repo assets/icon/acare_logo.png.
# VIETQR_ACARE_LOGO_PATH=/data/import/acare_logo.png
