// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

// ============================================================
// STORE
// ============================================================
model Store {
  id                      String   @id @default(uuid())
  storeId                 String   @unique // e.g. "HCM01", "HN02"
  storeName               String
  transferAccountNumber   String?
  transferAccountName     String?
  transferBankName        String?
  transferBankBin         String?
  mapVietinUsername       String?
  mapVietinPasswordCipher String?
  createdAt               DateTime @default(now())
  updatedAt               DateTime @updatedAt

  users User[]
}

model VietQrPaymentIntent {
  id                        String    @id @default(uuid())
  storeCode                 String
  createdById               String?
  createdBy                 User?     @relation(fields: [createdById], references: [id])
  amount                    Int?
  orderCode                 String?
  transferContent           String
  qrPayload                 String
  status                    String    @default("PENDING")
  matchedTransactionId      String?
  matchedTransactionNumber  String?
  matchedAmount             Int?
  matchedTranTime           DateTime?
  matchedPayerName          String?
  matchedPayerAccount       String?
  matchedTransactionContent String?
  confirmedAt               DateTime?
  lastCheckedAt             DateTime?
  lastCheckResult           Json?
  createdAt                 DateTime  @default(now())
  updatedAt                 DateTime  @updatedAt

  @@index([storeCode, createdAt])
  @@index([status, createdAt])
}

model MapVietinTransaction {
  id                   String    @id @default(uuid())
  storeCode            String
  transactionKey       String    @unique
  transactionNumber    String?
  amount               Int
  content              String
  orders               String[]  @default([])
  orderSource          String?
  orderUpdatedAt       DateTime?
  orderUpdatedByUserId String?
  orderUpdatedByEmail  String?
  status               String?
  paidAt               DateTime?
  payerName            String?
  payerAccount         String?
  rawData              Json
  firstSeenAt          DateTime  @default(now())
  createdAt            DateTime  @default(now())
  updatedAt            DateTime  @updatedAt

  orderAudits MapVietinTransactionOrderAudit[]

  @@index([storeCode, paidAt])
  @@index([storeCode, firstSeenAt])
  @@index([amount])
  @@index([orders], type: Gin)
}

model MapVietinTransactionOrderAudit {
  id              String               @id @default(uuid())
  transactionId   String
  transaction     MapVietinTransaction @relation(fields: [transactionId], references: [id], onDelete: Cascade)
  storeCode       String
  oldOrders       String[]             @default([])
  newOrders       String[]             @default([])
  changedByUserId String?
  changedByEmail  String?
  source          String               @default("MANUAL")
  createdAt       DateTime             @default(now())

  @@index([transactionId, createdAt])
  @@index([storeCode, createdAt])
}

model MapVietinUnmappedTransaction {
  id                String   @id @default(uuid())
  unmappedKey       String   @unique
  virtualAccount    String?
  reason            String
  transactionNumber String?
  amount            Int?
  content           String
  status            String?
  paidAt            DateTime?
  payerName         String?
  payerAccount      String?
  rawData           Json
  firstSeenAt       DateTime @default(now())
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt

  @@index([reason, firstSeenAt])
  @@index([virtualAccount, firstSeenAt])
}

model MapVietinSyncState {
  id            String   @id @default(uuid())
  storeCode     String   @unique
  lastSyncedAt  DateTime?
  lastSuccessAt DateTime?
  lastError     String?
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
}

model PaymentNotification {
  id            String    @id @default(uuid())
  storeCode     String
  transactionId String    @unique
  text          String
  amount        Int
  audioStatus   String    @default("PENDING")
  audioPath     String?
  audioMime     String?
  audioError    String?
  expiresAt     DateTime
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  @@index([storeCode, createdAt])
  @@index([expiresAt])
}

model PaymentNotificationDeliveryLog {
  id             String   @id @default(uuid())
  notificationId String
  transactionId  String?
  storeCode      String
  userId         String?
  clientId       String?
  event          String
  error          String?
  createdAt      DateTime @default(now())

  @@index([notificationId, createdAt])
  @@index([storeCode, createdAt])
  @@index([createdAt])
}

model AppLog {
  id        String   @id @default(uuid())
  level     String
  source    String
  message   String
  userId    String?
  clientId  String?
  storeCode String?
  context   Json?
  createdAt DateTime @default(now())

  @@index([createdAt])
  @@index([source, createdAt])
  @@index([storeCode, createdAt])
}

// ============================================================
// USER
// ============================================================
model User {
  id                 String    @id @default(uuid())
  email              String    @unique
  password           String
  firstName          String
  lastName           String?
  role               String    @default("STAFF")
  status             String    @default("yes") // "yes" = active, "no" = locked
  avatarUrl          String?
  profileCompletedAt DateTime?
  branchLockedAt     DateTime?
  createdAt          DateTime  @default(now())
  updatedAt          DateTime  @updatedAt

  // Store relationship (nullable: admin users may not belong to a store)
  storeId String?
  store   Store?  @relation(fields: [storeId], references: [id])

  // Personnel assignment (separate from system access role)
  departmentCode String?
  department     DepartmentDefinition? @relation(fields: [departmentCode], references: [code])
  jobRoleCode    String?
  jobRole        JobRoleDefinition?    @relation(fields: [jobRoleCode], references: [code])
  workScopeType  String?

  warrantiesCreated Warranty[]            @relation("CreatedBy")
  warrantiesHandled Warranty[]            @relation("HandledBy")
  feedbacks         Feedback[]
  fifoLogs          FifoLog[]
  vietQrPayments    VietQrPaymentIntent[]

  @@index([departmentCode])
  @@index([jobRoleCode])
  @@index([workScopeType])
}

model RoleDefinition {
  id          String   @id @default(uuid())
  code        String   @unique
  displayName String
  description String?
  isSystem    Boolean  @default(false)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model DepartmentDefinition {
  id          String   @id @default(uuid())
  code        String   @unique
  displayName String
  description String?
  isSystem    Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  users User[]
}

model JobRoleDefinition {
  id             String   @id @default(uuid())
  code           String   @unique
  displayName    String
  description    String?
  departmentCode String?
  isSystem       Boolean  @default(true)
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  users User[]

  @@index([departmentCode])
}

model EmailVerificationCode {
  id         String    @id @default(uuid())
  email      String
  purpose    String
  codeHash   String
  expiresAt  DateTime
  consumedAt DateTime?
  attempts   Int       @default(0)
  createdAt  DateTime  @default(now())

  @@index([email, purpose, createdAt])
}

// ============================================================
// WARRANTY (Bảo hành)
// The "bhsc" workflow. Images stored on VPS filesystem.
// ============================================================
model Warranty {
  id            String         @id @default(uuid())
  receipt       String         @unique // Mã phiếu bảo hành (receipt number)
  customerName  String?
  customerPhone String?
  productName   String?
  serialNumber  String?
  issue         String?
  status        WarrantyStatus @default(RECEIVED)
  note          String?
  imageLinks    String? // Ảnh lưu VPS, đây là chuỗi link phân cách bằng ";"

  createdById String
  createdBy   User   @relation("CreatedBy", fields: [createdById], references: [id])

  handledById String?
  handledBy   User?   @relation("HandledBy", fields: [handledById], references: [id])

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

enum WarrantyStatus {
  RECEIVED // Đã tiếp nhận
  PROCESSING // Đang xử lý
  DONE // Đã xong
  RETURNED // Đã trả khách
}

// ============================================================
// INVENTORY (inv-app)
// Synced from Google Sheets every hour via cron job.
// ============================================================
model Inventory {
  id           String    @id @default(uuid())
  sku          String
  skuName      String    @map("sku_name")
  serialNumber String?   @map("serial_number")
  bin          String?
  zone         String?
  importDate   DateTime? @map("import_date")
  count        Int       @default(1)
  fifo         Boolean   @default(false)
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt

  @@index([sku])
  @@index([bin])
  @@map("inventory")
}

// ============================================================
// FEEDBACK
// ============================================================
model Feedback {
  id        String   @id @default(uuid())
  content   String
  rating    Int      @default(5)
  userId    String
  user      User     @relation(fields: [userId], references: [id])
  createdAt DateTime @default(now())
}

// ============================================================
// FIFO LOG (Lịch sử Kiểm tra FIFO & Sắp xếp FIFO)
// ============================================================
model FifoLog {
  id         String      @id @default(uuid())
  type       FifoLogType
  query      String // SKU/Serial/BIN mà user nhập
  result     String? // Tóm tắt kết quả
  resultJson Json?       @map("result_json") // Full JSON response
  userId     String
  user       User        @relation(fields: [userId], references: [id])
  createdAt  DateTime    @default(now())

  @@index([userId])
  @@index([createdAt])
  @@map("fifo_logs")
}

enum FifoLogType {
  FIFO_CHECK
  FIFO_SORT
}
