// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

// ============================================================
// STORE
// ============================================================
model Store {
  id                      String            @id @default(uuid())
  storeId                 String            @unique // e.g. "HCM01", "HN02"
  storeName               String
  areaCode                String?
  area                    AreaDefinition?   @relation(fields: [areaCode], references: [code])
  organizationNodeId      String?
  organizationNode        OrganizationNode? @relation(fields: [organizationNodeId], references: [id], onUpdate: Cascade)
  transferAccountNumber   String?
  transferAccountName     String?
  transferBankName        String?
  transferBankBin         String?
  mapVietinUsername       String?
  mapVietinPasswordCipher String?
  createdAt               DateTime          @default(now())
  updatedAt               DateTime          @updatedAt

  users            User[]
  quickActionLinks QuickActionLink[]

  featureAccessRules FeatureAccessRule[]

  @@index([areaCode])
  @@index([organizationNodeId])
}

model VietQrPaymentIntent {
  id                        String    @id @default(uuid())
  storeCode                 String
  createdById               String?
  createdBy                 User?     @relation(fields: [createdById], references: [id])
  amount                    Int?
  orderCode                 String?
  transferContent           String
  qrPayload                 String
  status                    String    @default("PENDING")
  matchedTransactionId      String?
  matchedTransactionNumber  String?
  matchedAmount             Int?
  matchedTranTime           DateTime?
  matchedPayerName          String?
  matchedPayerAccount       String?
  matchedTransactionContent String?
  confirmedAt               DateTime?
  lastCheckedAt             DateTime?
  lastCheckResult           Json?
  createdAt                 DateTime  @default(now())
  updatedAt                 DateTime  @updatedAt

  @@index([storeCode, createdAt])
  @@index([status, createdAt])
}

model MapVietinTransaction {
  id                        String    @id @default(uuid())
  storeCode                 String?
  transactionKey            String    @unique
  transactionNumber         String?
  amount                    Int
  content                   String
  orders                    String[]  @default([])
  orderSource               String?
  orderUpdatedAt            DateTime?
  orderUpdatedByUserId      String?
  orderUpdatedByEmail       String?
  status                    String?
  paidAt                    DateTime?
  payerName                 String?
  payerAccount              String?
  incomeType                String    @default("SALES")
  incomeTypeSource          String    @default("AUTO")
  incomeTypeUpdatedAt       DateTime?
  incomeTypeUpdatedByUserId String?
  incomeTypeUpdatedByEmail  String?
  rawData                   Json
  firstSeenAt               DateTime  @default(now())
  createdAt                 DateTime  @default(now())
  updatedAt                 DateTime  @updatedAt

  orderAudits           MapVietinTransactionOrderAudit[]
  orderTransferRequests MapVietinStatementOrderTransferRequest[]

  @@index([storeCode, paidAt])
  @@index([storeCode, firstSeenAt])
  @@index([storeCode, incomeType, paidAt])
  @@index([incomeType, paidAt])
  @@index([amount])
  @@index([orders], type: Gin)
}

model MapVietinTransactionOrderAudit {
  id              String               @id @default(uuid())
  transactionId   String
  transaction     MapVietinTransaction @relation(fields: [transactionId], references: [id], onDelete: Cascade)
  storeCode       String?
  oldOrders       String[]             @default([])
  newOrders       String[]             @default([])
  changedByUserId String?
  changedByEmail  String?
  source          String               @default("MANUAL")
  createdAt       DateTime             @default(now())

  @@index([transactionId, createdAt])
  @@index([storeCode, createdAt])
}

model MapVietinStatementOrderTransferRequest {
  id                String               @id @default(uuid())
  transactionId     String
  transaction       MapVietinTransaction @relation(fields: [transactionId], references: [id], onDelete: Cascade)
  storeCode         String
  oldOrders         String[]             @default([])
  requestedOrders   String[]             @default([])
  status            String               @default("PENDING")
  requestedByUserId String?
  requestedByEmail  String?
  reviewedByUserId  String?
  reviewedByEmail   String?
  reviewNote        String?
  reviewedAt        DateTime?
  createdAt         DateTime             @default(now())
  updatedAt         DateTime             @updatedAt

  @@index([transactionId, status])
  @@index([storeCode, status, createdAt])
  @@index([status, createdAt])
}

model MapVietinUnmappedTransaction {
  id                String    @id @default(uuid())
  unmappedKey       String    @unique
  virtualAccount    String?
  reason            String
  transactionNumber String?
  amount            Int?
  content           String
  status            String?
  paidAt            DateTime?
  payerName         String?
  payerAccount      String?
  rawData           Json
  firstSeenAt       DateTime  @default(now())
  createdAt         DateTime  @default(now())
  updatedAt         DateTime  @updatedAt

  @@index([reason, firstSeenAt])
  @@index([virtualAccount, firstSeenAt])
}

model MapVietinSyncState {
  id            String    @id @default(uuid())
  storeCode     String    @unique
  lastSyncedAt  DateTime?
  lastSuccessAt DateTime?
  lastError     String?
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt
}

model OffsetAdjustment {
  id               String    @id @default(uuid())
  type             String
  status           String    @default("PENDING_ACC")
  storeCode        String
  oldOrderCode     String?
  newOrderCode     String?
  orderCode        String?
  scanDate         DateTime?
  editContentKind  String?
  transactionCode  String?
  amount           Int
  note             String?
  ctCode           String?
  rejectReason     String?
  createdByUserId  String?
  createdByEmail   String?
  reviewedByUserId String?
  reviewedByEmail  String?
  submittedAt      DateTime  @default(now())
  reviewedAt       DateTime?
  createdAt        DateTime  @default(now())
  updatedAt        DateTime  @updatedAt

  history OffsetAdjustmentHistory[]

  @@unique([type, orderCode])
  @@unique([type, transactionCode])
  @@index([storeCode, submittedAt])
  @@index([status, submittedAt])
  @@index([type, submittedAt])
  @@index([oldOrderCode])
  @@index([newOrderCode])
  @@index([amount])
}

model OffsetAdjustmentHistory {
  id           String           @id @default(uuid())
  adjustmentId String
  adjustment   OffsetAdjustment @relation(fields: [adjustmentId], references: [id], onDelete: Cascade)
  action       String
  fromStatus   String?
  toStatus     String?
  actorUserId  String?
  actorEmail   String?
  reason       String?
  snapshot     Json?
  createdAt    DateTime         @default(now())

  @@index([adjustmentId, createdAt])
  @@index([action, createdAt])
}

model AppNotificationReadReceipt {
  id             String   @id @default(uuid())
  userId         String
  user           User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  source         String
  notificationId String
  readAt         DateTime @default(now())
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  @@unique([userId, source, notificationId])
  @@index([source, notificationId])
  @@index([userId, readAt])
}

model PaymentNotification {
  id            String   @id @default(uuid())
  storeCode     String
  transactionId String   @unique
  text          String
  amount        Int
  audioStatus   String   @default("PENDING")
  audioPath     String?
  audioMime     String?
  audioError    String?
  expiresAt     DateTime
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  @@index([storeCode, createdAt])
  @@index([expiresAt])
}

model PaymentNotificationDeliveryLog {
  id             String   @id @default(uuid())
  notificationId String
  transactionId  String?
  storeCode      String
  userId         String?
  clientId       String?
  event          String
  error          String?
  createdAt      DateTime @default(now())

  @@index([notificationId, createdAt])
  @@index([storeCode, createdAt])
  @@index([clientId, storeCode, event, createdAt], map: "PaymentDeliveryLog_client_store_event_createdAt_idx")
  @@index([createdAt])
}

model AppLog {
  id        String   @id @default(uuid())
  level     String
  source    String
  message   String
  userId    String?
  clientId  String?
  storeCode String?
  context   Json?
  createdAt DateTime @default(now())

  @@index([createdAt])
  @@index([source, createdAt])
  @@index([storeCode, createdAt])
}

// ============================================================
// USER
// ============================================================
model User {
  id                 String    @id @default(uuid())
  email              String    @unique
  password           String
  tokenVersion       Int       @default(0)
  accessVersion      Int       @default(0)
  firstName          String
  lastName           String?
  role               String    @default("USER")
  status             String    @default("yes") // "yes" = active, "no" = locked
  avatarUrl          String?
  profileCompletedAt DateTime?
  branchLockedAt     DateTime?
  createdAt          DateTime  @default(now())
  updatedAt          DateTime  @updatedAt

  // Store relationship (nullable: admin users may not belong to a store)
  storeId String?
  store   Store?  @relation(fields: [storeId], references: [id])

  // Personnel assignment (separate from system access role)
  departmentCode     String?
  department         DepartmentDefinition? @relation(fields: [departmentCode], references: [code])
  jobRoleCode        String?
  jobRole            JobRoleDefinition?    @relation(fields: [jobRoleCode], references: [code])
  workScopeType      String?
  regionCode         String?
  region             RegionDefinition?     @relation(fields: [regionCode], references: [code])
  areaCode           String?
  area               AreaDefinition?       @relation(fields: [areaCode], references: [code])
  organizationNodeId String?
  organizationNode   OrganizationNode?     @relation(fields: [organizationNodeId], references: [id], onUpdate: Cascade)

  warrantiesCreated              Warranty[]                          @relation("CreatedBy")
  warrantiesHandled              Warranty[]                          @relation("HandledBy")
  feedbacks                      Feedback[]
  salesReportsCreated            SalesReport[]
  fifoLogs                       FifoLog[]
  vietQrPayments                 VietQrPaymentIntent[]
  passwordResetTokens            PasswordResetToken[]
  platformSessions               UserPlatformSession[]
  featureAccessRules             FeatureAccessRule[]
  userFeatureAssignments         UserFeatureAssignment[]
  organizationAssignments        UserOrganizationAssignment[]
  nodeFeatureAssignmentsAssigned OrganizationNodeFeatureAssignment[] @relation("NodeFeatureAssignedBy")
  notificationReadReceipts       AppNotificationReadReceipt[]
  quickActionLinksUpdated        QuickActionLink[]                   @relation("QuickActionLinkUpdatedBy")
  contractAppendices             ContractAppendix[]

  @@index([departmentCode])
  @@index([jobRoleCode])
  @@index([workScopeType])
  @@index([regionCode])
  @@index([areaCode])
  @@index([organizationNodeId])
  @@index([createdAt])
  @@index([status, createdAt])
}

model QuickActionLink {
  id          String   @id @default(uuid())
  storeCode   String
  store       Store    @relation(fields: [storeCode], references: [storeId], onDelete: Cascade, onUpdate: Cascade)
  actionCode  String
  url         String   @db.VarChar(2048)
  updatedById String?
  updatedBy   User?    @relation("QuickActionLinkUpdatedBy", fields: [updatedById], references: [id], onDelete: SetNull, onUpdate: Cascade)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@unique([storeCode, actionCode])
  @@index([actionCode])
  @@index([updatedById])
}

model UserOrganizationAssignment {
  id                 String           @id @default(uuid())
  userId             String
  user               User             @relation(fields: [userId], references: [id], onDelete: Cascade, onUpdate: Cascade)
  organizationNodeId String
  organizationNode   OrganizationNode @relation(fields: [organizationNodeId], references: [id], onDelete: Restrict, onUpdate: Cascade)
  isPrimary          Boolean          @default(false)
  isActive           Boolean          @default(true)
  assignedById       String?
  note               String?
  createdAt          DateTime         @default(now())
  updatedAt          DateTime         @updatedAt

  @@unique([userId, organizationNodeId])
  @@index([userId, isActive])
  @@index([organizationNodeId, isActive])
}

model UserPlatformSession {
  id             String    @id @default(uuid())
  userId         String
  user           User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  platform       String
  sessionVersion Int       @default(1)
  deviceIdHash   String
  deviceLabel    String?
  appVersion     String?
  buildNumber    String?
  lastLoginAt    DateTime  @default(now())
  expiresAt      DateTime
  revokedAt      DateTime?
  revokedReason  String?
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt

  @@unique([userId, platform])
  @@index([userId])
  @@index([platform])
  @@index([expiresAt])
  @@index([revokedAt])
}

model PasswordResetToken {
  id              String    @id @default(uuid())
  userId          String
  user            User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  email           String
  purpose         String    @default("PASSWORD_RESET")
  tokenHash       String    @unique
  expiresAt       DateTime
  consumedAt      DateTime?
  attempts        Int       @default(0)
  source          String
  createdByUserId String?
  createdByEmail  String?
  createdAt       DateTime  @default(now())

  @@index([userId, createdAt])
  @@index([email, createdAt])
  @@index([expiresAt])
}

model RoleDefinition {
  id          String   @id @default(uuid())
  code        String   @unique
  displayName String
  description String?
  isSystem    Boolean  @default(false)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model DepartmentDefinition {
  id                 String            @id @default(uuid())
  code               String            @unique
  displayName        String
  description        String?
  organizationNodeId String?
  organizationNode   OrganizationNode? @relation(fields: [organizationNodeId], references: [id], onUpdate: Cascade)
  isSystem           Boolean           @default(true)
  isActive           Boolean           @default(true)
  createdAt          DateTime          @default(now())
  updatedAt          DateTime          @updatedAt

  users              User[]
  featureAccessRules FeatureAccessRule[]

  @@index([organizationNodeId])
}

model JobRoleDefinition {
  id                 String            @id @default(uuid())
  code               String            @unique
  displayName        String
  description        String?
  departmentCode     String?
  organizationNodeId String?
  organizationNode   OrganizationNode? @relation(fields: [organizationNodeId], references: [id], onUpdate: Cascade)
  isSystem           Boolean           @default(true)
  isActive           Boolean           @default(true)
  createdAt          DateTime          @default(now())
  updatedAt          DateTime          @updatedAt

  users              User[]
  featureAccessRules FeatureAccessRule[]

  @@index([departmentCode])
  @@index([organizationNodeId])
}

model RegionDefinition {
  id                 String            @id @default(uuid())
  code               String            @unique
  displayName        String
  abbreviation       String
  description        String?
  organizationNodeId String?
  organizationNode   OrganizationNode? @relation(fields: [organizationNodeId], references: [id], onUpdate: Cascade)
  isSystem           Boolean           @default(false)
  isActive           Boolean           @default(true)
  createdAt          DateTime          @default(now())
  updatedAt          DateTime          @updatedAt

  areas              AreaDefinition[]
  users              User[]
  featureAccessRules FeatureAccessRule[]

  @@index([organizationNodeId])
}

model AreaDefinition {
  id                 String            @id @default(uuid())
  code               String            @unique
  displayName        String
  abbreviation       String
  description        String?
  regionCode         String
  region             RegionDefinition  @relation(fields: [regionCode], references: [code])
  organizationNodeId String?
  organizationNode   OrganizationNode? @relation(fields: [organizationNodeId], references: [id], onUpdate: Cascade)
  isSystem           Boolean           @default(false)
  isActive           Boolean           @default(true)
  createdAt          DateTime          @default(now())
  updatedAt          DateTime          @updatedAt

  stores             Store[]
  users              User[]
  featureAccessRules FeatureAccessRule[]

  @@index([regionCode])
  @@index([organizationNodeId])
}

model OrganizationNode {
  id           String             @id @default(uuid())
  code         String             @unique
  displayName  String
  businessCode String?
  abbreviation String?
  description  String?
  type         String
  parentId     String?
  parent       OrganizationNode?  @relation("OrganizationNodeChildren", fields: [parentId], references: [id], onDelete: Restrict, onUpdate: Cascade)
  children     OrganizationNode[] @relation("OrganizationNodeChildren")
  emailDomain  String?
  loginAllowed Boolean            @default(false)
  isSystem     Boolean            @default(false)
  isActive     Boolean            @default(true)
  sortOrder    Int                @default(0)
  metadata     Json?
  createdAt    DateTime           @default(now())
  updatedAt    DateTime           @updatedAt

  stores                 Store[]
  users                  User[]
  departments            DepartmentDefinition[]
  jobRoles               JobRoleDefinition[]
  regions                RegionDefinition[]
  areas                  AreaDefinition[]
  featureAccessRules     FeatureAccessRule[]
  adminPolicyRules       AdminPolicyRule[]
  userAssignments        UserOrganizationAssignment[]
  nodeFeatureAssignments OrganizationNodeFeatureAssignment[] @relation("NodeFeatureScopeRoot")
  salesTargets           SalesTarget[]

  @@index([parentId])
  @@index([type])
  @@index([businessCode])
  @@index([emailDomain])
  @@index([isActive])
}

model FeatureDefinition {
  id                  String   @id @default(uuid())
  code                String   @unique
  displayName         String
  description         String?
  parentCode          String?
  sortOrder           Int      @default(0)
  visibleInUserPicker Boolean  @default(true)
  isSystem            Boolean  @default(true)
  isActive            Boolean  @default(true)
  createdAt           DateTime @default(now())
  updatedAt           DateTime @updatedAt

  rules           FeatureAccessRule[]
  userAssignments UserFeatureAssignment[]
  nodeAssignments OrganizationNodeFeatureAssignment[]

  @@index([parentCode])
  @@index([visibleInUserPicker])
}

model UserFeatureAssignment {
  id           String            @id @default(uuid())
  userId       String
  user         User              @relation(fields: [userId], references: [id], onDelete: Cascade, onUpdate: Cascade)
  featureCode  String
  feature      FeatureDefinition @relation(fields: [featureCode], references: [code], onDelete: Cascade, onUpdate: Cascade)
  enabled      Boolean           @default(true)
  assignedById String?
  note         String?
  createdAt    DateTime          @default(now())
  updatedAt    DateTime          @updatedAt

  @@unique([userId, featureCode])
  @@index([featureCode])
  @@index([assignedById])
  @@index([enabled])
}

model OrganizationNodeFeatureAssignment {
  id              String            @id @default(uuid())
  scopeRootNodeId String
  scopeRootNode   OrganizationNode  @relation("NodeFeatureScopeRoot", fields: [scopeRootNodeId], references: [id], onDelete: Restrict, onUpdate: Cascade)
  nodeType        String
  nodeKey         String
  featureCode     String
  feature         FeatureDefinition @relation(fields: [featureCode], references: [code], onDelete: Cascade, onUpdate: Cascade)
  enabled         Boolean           @default(true)
  assignedById    String?
  assignedBy      User?             @relation("NodeFeatureAssignedBy", fields: [assignedById], references: [id], onDelete: SetNull, onUpdate: Cascade)
  note            String?
  createdAt       DateTime          @default(now())
  updatedAt       DateTime          @updatedAt

  @@unique([scopeRootNodeId, nodeType, nodeKey, featureCode])
  @@index([scopeRootNodeId])
  @@index([nodeType, nodeKey])
  @@index([featureCode])
  @@index([enabled])
  @@index([featureCode, enabled, scopeRootNodeId])
  @@index([assignedById])
}

model FeatureAccessRule {
  id                 String                @id @default(uuid())
  featureCode        String
  feature            FeatureDefinition     @relation(fields: [featureCode], references: [code], onDelete: Cascade, onUpdate: Cascade)
  enabled            Boolean
  emailDomain        String?
  systemRole         String?
  departmentCode     String?
  department         DepartmentDefinition? @relation(fields: [departmentCode], references: [code], onUpdate: Cascade)
  jobRoleCode        String?
  jobRole            JobRoleDefinition?    @relation(fields: [jobRoleCode], references: [code], onUpdate: Cascade)
  workScopeType      String?
  regionCode         String?
  region             RegionDefinition?     @relation(fields: [regionCode], references: [code], onUpdate: Cascade)
  areaCode           String?
  organizationNodeId String?
  organizationNode   OrganizationNode?     @relation(fields: [organizationNodeId], references: [id], onUpdate: Cascade)
  area               AreaDefinition?       @relation(fields: [areaCode], references: [code], onUpdate: Cascade)
  storeCode          String?
  store              Store?                @relation(fields: [storeCode], references: [storeId], onUpdate: Cascade)
  userId             String?
  user               User?                 @relation(fields: [userId], references: [id], onDelete: Cascade, onUpdate: Cascade)
  note               String?
  createdAt          DateTime              @default(now())
  updatedAt          DateTime              @updatedAt

  @@index([featureCode])
  @@index([emailDomain])
  @@index([systemRole])
  @@index([departmentCode])
  @@index([jobRoleCode])
  @@index([workScopeType])
  @@index([regionCode])
  @@index([areaCode])
  @@index([organizationNodeId])
  @@index([storeCode])
  @@index([userId])
}

model AdminPolicyDefinition {
  id             String   @id @default(uuid())
  code           String   @unique
  displayName    String
  description    String?
  category       String   @default("GENERAL")
  defaultAllowed Boolean  @default(false)
  isSystem       Boolean  @default(true)
  isActive       Boolean  @default(true)
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  rules AdminPolicyRule[]
}

model AdminPolicyRule {
  id                 String                @id @default(uuid())
  policyCode         String
  policy             AdminPolicyDefinition @relation(fields: [policyCode], references: [code], onDelete: Cascade, onUpdate: Cascade)
  allowed            Boolean
  emailDomain        String?
  systemRole         String?
  departmentCode     String?
  jobRoleCode        String?
  workScopeType      String?
  regionCode         String?
  areaCode           String?
  organizationNodeId String?
  organizationNode   OrganizationNode?     @relation(fields: [organizationNodeId], references: [id], onUpdate: Cascade)
  storeCode          String?
  userId             String?
  scopeContains      String?
  note               String?
  isSystem           Boolean               @default(false)
  createdAt          DateTime              @default(now())
  updatedAt          DateTime              @updatedAt

  @@index([policyCode])
  @@index([emailDomain])
  @@index([systemRole])
  @@index([departmentCode])
  @@index([jobRoleCode])
  @@index([workScopeType])
  @@index([regionCode])
  @@index([areaCode])
  @@index([organizationNodeId])
  @@index([storeCode])
  @@index([userId])
  @@index([policyCode, updatedAt])
}

model AdminSetting {
  id          String   @id @default(uuid())
  key         String   @unique
  displayName String
  description String?
  value       Json
  category    String   @default("GENERAL")
  isSystem    Boolean  @default(true)
  isSensitive Boolean  @default(false)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([category])
}

model EmailVerificationCode {
  id         String    @id @default(uuid())
  email      String
  purpose    String
  codeHash   String
  expiresAt  DateTime
  consumedAt DateTime?
  attempts   Int       @default(0)
  createdAt  DateTime  @default(now())

  @@index([email, purpose, createdAt])
}

// ============================================================
// WARRANTY (Bảo hành)
// The "bhsc" workflow. Images stored on VPS filesystem.
// ============================================================
model Warranty {
  id            String         @id @default(uuid())
  receipt       String         @unique // Mã phiếu bảo hành (receipt number)
  customerName  String?
  customerPhone String?
  productName   String?
  serialNumber  String?
  issue         String?
  status        WarrantyStatus @default(RECEIVED)
  note          String?
  imageLinks    String? // Ảnh lưu VPS, đây là chuỗi link phân cách bằng ";"

  createdById String
  createdBy   User   @relation("CreatedBy", fields: [createdById], references: [id])

  handledById String?
  handledBy   User?   @relation("HandledBy", fields: [handledById], references: [id])

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

// Private user-generated media. `storageKey` is always an opaque server-side
// key below PRIVATE_MEDIA_BASE_DIR; clients receive only /media/:id URLs.
model MediaObject {
  id                  String    @id @default(uuid())
  storageKey          String    @unique
  ownerFeature        String
  ownerRecordId       String
  uploaderId          String
  originalName        String?
  contentTypeVerified String
  sizeBytes           Int
  checksumSha256      String
  visibility          String    @default("PRIVATE")
  legacyUrl           String?
  expiresAt           DateTime?
  deletedAt           DateTime?
  createdAt           DateTime  @default(now())
  updatedAt           DateTime  @updatedAt

  @@unique([legacyUrl, ownerFeature, ownerRecordId])
  @@index([ownerFeature, ownerRecordId, deletedAt])
  @@index([uploaderId, createdAt])
  @@index([checksumSha256])
}

enum WarrantyStatus {
  RECEIVED // Đã tiếp nhận
  PROCESSING // Đang xử lý
  DONE // Đã xong
  RETURNED // Đã trả khách
}

// ============================================================
// INVENTORY (inv-app)
// Synced from Google Sheets every hour via cron job.
// ============================================================
model Inventory {
  id           String    @id @default(uuid())
  sku          String
  skuName      String    @map("sku_name")
  serialNumber String?   @map("serial_number")
  bin          String?
  zone         String?
  importDate   DateTime? @map("import_date")
  count        Int       @default(1)
  fifo         Boolean   @default(false)
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt

  @@index([sku])
  @@index([bin])
  @@map("inventory")
}

// ============================================================
// FEEDBACK
// ============================================================
model Feedback {
  id        String   @id @default(uuid())
  content   String
  rating    Int      @default(5)
  userId    String
  user      User     @relation(fields: [userId], references: [id])
  createdAt DateTime @default(now())
}

// ============================================================
// SALES REPORT
// ============================================================
model SalesReportCategoryGroup {
  id             String   @id
  catGroupName   String
  catGroupNameVi String
  sourceRowCount Int      @default(0)
  sortOrder      Int      @default(0)
  isActive       Boolean  @default(true)
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  reports          SalesReport[]
  reportSelections SalesReportCategorySelection[]

  @@index([isActive, sortOrder])
}

model SalesReportImportBatch {
  id               String    @id @default(uuid())
  fileName         String
  fileHash         String
  status           String    @default("PROCESSING")
  importedByUserId String?
  importedByEmail  String?
  importedByName   String?
  totalRows        Int       @default(0)
  validRows        Int       @default(0)
  importedRows     Int       @default(0)
  purchasedRows    Int       @default(0)
  duplicateRows    Int       @default(0)
  invalidRows      Int       @default(0)
  unassignedRows   Int       @default(0)
  createdAt        DateTime  @default(now())
  completedAt      DateTime?

  reports SalesReport[]

  @@index([fileHash, createdAt])
  @@index([importedByUserId, createdAt])
  @@index([status, createdAt])
}

model SalesReport {
  id                             String                   @id @default(uuid())
  reportType                     String
  orderCode                      String?                  @unique
  customerName                   String?
  customerPhone                  String?
  customerContactChannels        String[]                 @default([])
  customerZaloContact            String?
  customerNeed                   String?
  categoryGroupId                String
  categoryGroup                  SalesReportCategoryGroup @relation(fields: [categoryGroupId], references: [id], onUpdate: Cascade)
  categoryGroupName              String
  categoryGroupNameVi            String
  consultedSolutionAnswer        String
  consultedSolutionOtherReason   String?
  experiencedAnswer              String
  experiencedOtherReason         String?
  zaloAnswer                     String
  zaloOtherReason                String?
  appDownloadAnswer              String
  appDownloadOtherReason         String?
  notPurchasedReason             String?
  notPurchasedOtherReason        String?
  customerType                   String?
  customerIsStudent              Boolean                  @default(false)
  promotionCodes                 String[]                 @default([])
  installmentNeed                Boolean                  @default(false)
  installmentApproved            Boolean?
  installmentLoanAmount          Int?
  installmentNoInstallmentReason String?
  installmentStatus              String?
  installmentFailureReason       String?
  installmentPartnerCodes        String[]                 @default([])
  createdByUserId                String?
  createdBy                      User?                    @relation(fields: [createdByUserId], references: [id], onDelete: SetNull, onUpdate: Cascade)
  createdByEmail                 String?
  createdByName                  String?
  createdByPersonnelCode         String?
  sourceSalespersonCode          String?
  storeCode                      String?
  storeName                      String?
  organizationNodeId             String?
  organizationNodeName           String?
  regionCode                     String?
  areaCode                       String?
  erpOrderId                     String?
  erpExternalOrderRef            String?
  erpOrderCreatedAt              DateTime?
  erpPaymentStatus               String?
  erpConfirmationStatus          String?
  erpFulfillmentStatus           String?
  erpLifecycleStatus             String                   @default("PENDING")
  erpHasReturnedFullItems        Boolean                  @default(false)
  erpReturnedAfterTaxAmount      Int                      @default(0)
  erpStatusCheckedAt             DateTime?
  erpStatusCheckAttemptedAt      DateTime?
  erpStatusCheckAttemptDate      DateTime?                @db.Date
  erpStatusCheckAttemptCount     Int                      @default(0)
  erpStatusCheckFailureCount     Int                      @default(0)
  erpTerminalName                String?
  erpGrandTotal                  Int?
  erpPaymentMethods              String[]                 @default([])
  erpCustomerType                String?
  erpPlatformId                  Int?
  erpConsultantCustomId          String?
  erpConsultantName              String?
  erpSnapshot                    Json?
  erpFetchedAt                   DateTime?
  erpFetchStatus                 String?
  erpExcludedAt                  DateTime?
  erpExclusionReason             String?
  rawResponses                   Json?
  entrySource                    String?
  importFingerprint              String?                  @unique
  importBatchId                  String?
  importBatch                    SalesReportImportBatch?  @relation(fields: [importBatchId], references: [id], onDelete: SetNull, onUpdate: Cascade)
  submittedByUserId              String?
  submittedByEmail               String?
  submittedByName                String?
  submittedAt                    DateTime                 @default(now())
  createdAt                      DateTime                 @default(now())
  updatedAt                      DateTime                 @updatedAt

  items                    SalesReportOrderItem[]
  payments                 SalesReportPayment[]
  categorySelections       SalesReportCategorySelection[]
  sourceFollowUpCase       SalesReportFollowUpCase?       @relation("SalesReportFollowUpSource")
  convertedFollowUpCase    SalesReportFollowUpCase?       @relation("SalesReportFollowUpConverted")
  purchasedFollowUpEntries SalesReportFollowUpEntry[]     @relation("SalesReportFollowUpPurchase")

  @@index([reportType, submittedAt])
  @@index([storeCode, submittedAt])
  @@index([createdByUserId, submittedAt])
  @@index([categoryGroupId, submittedAt])
  @@index([erpOrderId])
  @@index([notPurchasedReason, submittedAt])
  @@index([installmentStatus, submittedAt])
  @@index([customerType, submittedAt])
  @@index([installmentNeed, submittedAt])
  @@index([organizationNodeId, submittedAt])
  @@index([erpExcludedAt, submittedAt])
  @@index([erpLifecycleStatus, erpStatusCheckedAt])
  @@index([erpLifecycleStatus, erpStatusCheckAttemptDate])
  @@index([entrySource, submittedAt])
  @@index([importBatchId])
}

model SalesReportFollowUpCase {
  id                    String       @id @default(uuid())
  sourceReportId        String       @unique
  sourceReport          SalesReport  @relation("SalesReportFollowUpSource", fields: [sourceReportId], references: [id], onDelete: Cascade, onUpdate: Cascade)
  status                String       @default("OPEN")
  assigneeUserId        String?
  assigneeEmail         String?
  assigneeName          String?
  assigneePersonnelCode String?
  assignedAt            DateTime?
  lastFollowUpAt        DateTime?
  lastFollowUpByUserId  String?
  lastFollowUpByEmail   String?
  lastFollowUpByName    String?
  followUpCount         Int          @default(0)
  priorityAt            DateTime
  convertedReportId     String?      @unique
  convertedReport       SalesReport? @relation("SalesReportFollowUpConverted", fields: [convertedReportId], references: [id], onDelete: SetNull, onUpdate: Cascade)
  closedAt              DateTime?
  createdAt             DateTime     @default(now())
  updatedAt             DateTime     @updatedAt

  entries SalesReportFollowUpEntry[]
  events  SalesReportFollowUpEvent[]

  @@index([status, priorityAt])
  @@index([assigneeUserId, status, priorityAt])
  @@index([assigneeEmail, status, priorityAt])
}

model SalesReportFollowUpEntry {
  id                      String                  @id @default(uuid())
  caseId                  String
  case                    SalesReportFollowUpCase @relation(fields: [caseId], references: [id], onDelete: Cascade, onUpdate: Cascade)
  sequenceNumber          Int
  outcome                 String
  notPurchasedReason      String?
  notPurchasedOtherReason String?
  actorUserId             String?
  actorEmail              String?
  actorName               String?
  purchasedReportId       String?                 @unique
  purchasedReport         SalesReport?            @relation("SalesReportFollowUpPurchase", fields: [purchasedReportId], references: [id], onDelete: SetNull, onUpdate: Cascade)
  contactedAt             DateTime                @default(now())
  createdAt               DateTime                @default(now())

  @@unique([caseId, sequenceNumber])
  @@index([caseId, contactedAt])
  @@index([outcome, contactedAt])
}

model SalesReportFollowUpEvent {
  id                 String                  @id @default(uuid())
  caseId             String
  case               SalesReportFollowUpCase @relation(fields: [caseId], references: [id], onDelete: Cascade, onUpdate: Cascade)
  eventType          String
  actorUserId        String?
  actorEmail         String?
  actorName          String?
  fromAssigneeUserId String?
  toAssigneeUserId   String?
  fromStatus         String?
  toStatus           String?
  createdAt          DateTime                @default(now())

  @@index([caseId, createdAt])
  @@index([eventType, createdAt])
}

model SalesReportCategorySelection {
  id                  String                   @id @default(uuid())
  salesReportId       String
  salesReport         SalesReport              @relation(fields: [salesReportId], references: [id], onDelete: Cascade, onUpdate: Cascade)
  categoryGroupId     String
  categoryGroup       SalesReportCategoryGroup @relation(fields: [categoryGroupId], references: [id], onDelete: Restrict, onUpdate: Cascade)
  categoryGroupName   String
  categoryGroupNameVi String
  sortOrder           Int                      @default(0)
  createdAt           DateTime                 @default(now())

  @@unique([salesReportId, categoryGroupId])
  @@index([salesReportId, sortOrder])
  @@index([categoryGroupId])
}

model SalesReportOrderItem {
  id               String      @id @default(uuid())
  salesReportId    String
  salesReport      SalesReport @relation(fields: [salesReportId], references: [id], onDelete: Cascade, onUpdate: Cascade)
  sku              String?
  sellerSku        String?
  name             String?
  brandCode        String?
  brandName        String?
  productTypeCode  String?
  productTypeName  String?
  productGroupId   String?
  productGroupCode String?
  productGroupName String?
  categoryType     String?
  quantity         Int?
  sellPrice        Int?
  finalSellPrice   Int?
  rowTotal         Int?
  raw              Json?
  createdAt        DateTime    @default(now())

  @@index([salesReportId])
  @@index([sku])
  @@index([sellerSku])
  @@index([brandName])
  @@index([productGroupName])
  @@index([categoryType])
}

model SalesReportPayment {
  id                     String      @id @default(uuid())
  salesReportId          String
  salesReport            SalesReport @relation(fields: [salesReportId], references: [id], onDelete: Cascade, onUpdate: Cascade)
  paymentMethod          String?
  amount                 Int?
  paidAt                 DateTime?
  transactionCode        String?
  partnerTransactionCode String?
  raw                    Json?
  createdAt              DateTime    @default(now())

  @@index([salesReportId])
  @@index([paymentMethod])
  @@index([paidAt])
}

model SalesReportErpOrderCache {
  id                      String    @id @default(uuid())
  orderCode               String    @unique
  erpOrderId              String?
  erpExternalOrderRef     String?
  orderCreatedAt          DateTime?
  paymentStatus           String?
  confirmationStatus      String?
  fulfillmentStatus       String?
  lifecycleStatus         String    @default("PENDING")
  hasReturnedFullItems    Boolean   @default(false)
  returnedAfterTaxAmount  Int       @default(0)
  statusCheckedAt         DateTime?
  statusCheckAttemptedAt  DateTime?
  statusCheckAttemptDate  DateTime? @db.Date
  statusCheckAttemptCount Int       @default(0)
  statusCheckFailureCount Int       @default(0)
  excludedAt              DateTime?
  exclusionReason         String?
  terminalName            String?
  grandTotal              Int?
  customerName            String?
  customerPhone           String?
  customerType            String?
  paymentMethods          String[]  @default([])
  platformId              Int?
  consultantCustomId      String?
  consultantName          String?
  consultantEmail         String?
  sellerId                String?
  sellerName              String?
  sellerEmail             String?
  storeCode               String?
  storeName               String?
  organizationNodeId      String?
  sourceUserId            String?
  sourceUserEmail         String?
  sanitizedSnapshot       Json?
  fetchedAt               DateTime
  createdAt               DateTime  @default(now())
  updatedAt               DateTime  @updatedAt

  @@index([orderCreatedAt])
  @@index([storeCode, orderCreatedAt])
  @@index([organizationNodeId, orderCreatedAt])
  @@index([consultantEmail, orderCreatedAt])
  @@index([sellerEmail, orderCreatedAt])
  @@index([sourceUserEmail, orderCreatedAt])
  @@index([consultantCustomId, orderCreatedAt])
  @@index([sellerId, orderCreatedAt])
  @@index([excludedAt, orderCreatedAt])
  @@index([lifecycleStatus, statusCheckedAt])
  @@index([lifecycleStatus, statusCheckAttemptDate])
  @@index([orderCreatedAt, lifecycleStatus, statusCheckedAt])
}

model SalesTarget {
  id                 String           @id @default(uuid())
  organizationNodeId String
  organizationNode   OrganizationNode @relation(fields: [organizationNodeId], references: [id], onDelete: Restrict, onUpdate: Cascade)
  monthStart         DateTime         @db.Date
  targetBeforeTax    BigInt
  updatedByUserId    String?
  updatedByEmail     String?
  createdAt          DateTime         @default(now())
  updatedAt          DateTime         @updatedAt

  @@unique([organizationNodeId, monthStart])
  @@index([monthStart])
  @@index([organizationNodeId, monthStart])
}

model HomeSummaryOrderFact {
  id                           String    @id @default(uuid())
  summaryDate                  DateTime
  orderCode                    String    @unique
  orderCreatedAt               DateTime?
  fetchedAt                    DateTime?
  storeCode                    String?
  storeName                    String?
  organizationNodeId           String?
  sourceUserId                 String?
  sourceUserEmail              String?
  consultantCustomId           String?
  consultantName               String?
  consultantEmail              String?
  sellerId                     String?
  sellerName                   String?
  sellerEmail                  String?
  grandTotal                   Int?
  isPaymentPending             Boolean   @default(false)
  hasValidReport               Boolean   @default(false)
  reportId                     String?
  reportSubmittedAt            DateTime?
  reportRevenue                Int?
  reportCreatedByUserId        String?
  reportCreatedByEmail         String?
  reportCreatedByPersonnelCode String?
  refreshedAt                  DateTime
  createdAt                    DateTime  @default(now())
  updatedAt                    DateTime  @updatedAt

  @@index([summaryDate, storeCode])
  @@index([summaryDate, organizationNodeId])
  @@index([summaryDate, sourceUserId])
  @@index([summaryDate, sourceUserEmail])
  @@index([summaryDate, consultantCustomId])
  @@index([summaryDate, consultantEmail])
  @@index([summaryDate, sellerId])
  @@index([summaryDate, sellerEmail])
  @@index([summaryDate, isPaymentPending])
}

model HomeSummaryReportFact {
  id                     String   @id @default(uuid())
  summaryDate            DateTime
  salesReportId          String   @unique
  reportType             String
  orderCode              String?
  createdByUserId        String?
  createdByEmail         String?
  createdByPersonnelCode String?
  storeCode              String?
  storeName              String?
  organizationNodeId     String?
  revenue                Int?
  submittedAt            DateTime
  refreshedAt            DateTime
  createdAt              DateTime @default(now())
  updatedAt              DateTime @updatedAt

  @@index([summaryDate, reportType])
  @@index([summaryDate, orderCode])
  @@index([summaryDate, storeCode])
  @@index([summaryDate, organizationNodeId])
  @@index([summaryDate, createdByUserId])
  @@index([summaryDate, createdByEmail])
  @@index([summaryDate, createdByPersonnelCode])
}

// Projection cộng dồn theo ngày để Home có thể mở rộng tới nhiều nghìn người dùng.
// dimensionType hiện nhận GLOBAL, STORE hoặc USER_STORE; chuỗi rỗng là khóa
// chuẩn cho các chiều không áp dụng, tránh unique key bị lọt do giá trị NULL.
model HomeSummaryDailyAggregate {
  id                  String    @id @default(uuid())
  summaryDate         DateTime  @db.Date
  projectionKind      String    @default("SALES")
  dimensionType       String
  dimensionKey        String    @default("")
  storeCode           String    @default("")
  totalOrders         Int       @default(0)
  reportedOrders      Int       @default(0)
  totalReports        Int       @default(0)
  notPurchasedReports Int       @default(0)
  orderRevenueAmount  BigInt    @default(0)
  reportRevenueAmount BigInt    @default(0)
  metrics             Json      @default("{}")
  projectionVersion   BigInt
  sourceUpdatedAt     DateTime?
  generatedAt         DateTime
  createdAt           DateTime  @default(now())
  updatedAt           DateTime  @updatedAt

  @@unique([summaryDate, projectionKind, dimensionType, dimensionKey, storeCode])
  @@index([projectionKind, dimensionType, dimensionKey, summaryDate])
  @@index([projectionKind, dimensionType, storeCode, summaryDate])
}

model HomeSummaryProjectionState {
  summaryDate                  DateTime  @id @db.Date
  status                       String
  projectionVersion            BigInt    @default(0)
  sourceUpdatedAt              DateTime?
  salesReportSourceUpdatedAt   DateTime?
  erpOrderCacheSourceUpdatedAt DateTime?
  mapVietinSourceUpdatedAt     DateTime?
  salesStatus                  String    @default("PENDING")
  salesProjectionVersion       BigInt    @default(0)
  salesGeneratedAt             DateTime?
  financeStatus                String    @default("PENDING")
  financeProjectionVersion     BigInt    @default(0)
  financeGeneratedAt           DateTime?
  generatedAt                  DateTime?
  lastError                    String?
  createdAt                    DateTime  @default(now())
  updatedAt                    DateTime  @updatedAt

  @@index([status, updatedAt])
}

// Queue bền vững kiêm coalescing key cho mỗi ngày/loại projection. Worker chỉ
// xóa row khi dirtyGeneration chưa tăng trong lúc rebuild; nếu source đổi thì
// lease được nhả thành đúng một follow-up job, không làm rơi event mới.
// Partial ready-claim index nằm trong migration vì Prisma chưa biểu diễn được.
model HomeSummaryProjectionQueue {
  id                String    @id @default(uuid())
  summaryDate       DateTime  @db.Date
  projectionKind    String    @default("SALES")
  dimensionType     String    @default("GLOBAL")
  dimensionKey      String    @default("")
  storeCode         String    @default("")
  sourceUpdatedAt   DateTime
  firstEnqueuedAt   DateTime  @default(now())
  availableAt       DateTime
  claimedAt         DateTime?
  claimToken        String?
  leaseExpiresAt    DateTime?
  dirtyGeneration   BigInt    @default(1)
  claimedGeneration BigInt?
  attempts          Int       @default(0)
  lastError         String?
  createdAt         DateTime  @default(now())
  updatedAt         DateTime  @updatedAt

  @@unique([summaryDate, projectionKind])
  @@index([availableAt, leaseExpiresAt])
}

model DomainOutboxEvent {
  id             String    @id @default(uuid())
  eventType      String
  aggregateType  String
  aggregateId    String
  dedupeKey      String?   @unique
  schemaVersion  Int       @default(1)
  payload        Json
  occurredAt     DateTime  @default(now())
  availableAt    DateTime  @default(now())
  publishedAt    DateTime?
  claimedAt      DateTime?
  claimToken     String?
  leaseExpiresAt DateTime?
  attempts       Int       @default(0)
  lastError      String?
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt

  @@index([publishedAt, availableAt])
  @@index([eventType, occurredAt])
}

model ErpOrderCacheBackfillCheckpoint {
  jobKey         String   @id
  startDate      DateTime @db.Date
  endDate        DateTime @db.Date
  currentDate    DateTime @db.Date
  nextOffset     Int      @default(0)
  status         String   @default("PENDING")
  pagesProcessed Int      @default(0)
  rowsProcessed  Int      @default(0)
  lastError      String?
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  @@index([status, updatedAt])
}

model HelpContentPage {
  id                  String    @id @default(uuid())
  key                 String    @unique
  title               String
  fileName            String
  parentKey           String?
  sortOrder           Int       @default(0)
  markdown            String
  isPublished         Boolean   @default(true)
  isAuthenticatedOnly Boolean   @default(false)
  updatedByUserId     String?
  updatedByEmail      String?
  seededFromDocsAt    DateTime?
  createdAt           DateTime  @default(now())
  updatedAt           DateTime  @updatedAt

  @@index([parentKey, sortOrder, key])
  @@index([isPublished, parentKey, sortOrder])
  @@index([isPublished, isAuthenticatedOnly, parentKey, sortOrder])
}

// ============================================================
// FIFO LOG (Lịch sử Kiểm tra FIFO & Sắp xếp FIFO)
// ============================================================
model FifoLog {
  id         String      @id @default(uuid())
  type       FifoLogType
  query      String // SKU/Serial/BIN mà user nhập
  result     String? // Tóm tắt kết quả
  resultJson Json?       @map("result_json") // Full JSON response
  userId     String
  user       User        @relation(fields: [userId], references: [id])
  createdAt  DateTime    @default(now())

  @@index([userId])
  @@index([createdAt])
  @@map("fifo_logs")
}

enum FifoLogType {
  FIFO_CHECK
  FIFO_SORT
}

// ============================================================
// CONTRACT APPENDIX (Phụ lục hợp đồng - lịch sử cá nhân 30 ngày)
// ============================================================
model ContractAppendix {
  id                   String                 @id @default(uuid())
  userId               String
  user                 User                   @relation(fields: [userId], references: [id], onDelete: Cascade)
  orderCode            String
  terminalCode         String
  totalBeforeVat       BigInt
  totalVatAmount       BigInt
  totalAfterVat        BigInt
  amountInWords        String
  manualTaxItemCount   Int                    @default(0)
  sourceOrderFetchedAt DateTime
  quoteFingerprint     String
  createdAt            DateTime               @default(now())
  expiresAt            DateTime
  items                ContractAppendixItem[]

  @@index([userId, createdAt])
  @@index([userId, orderCode, createdAt])
  @@index([expiresAt])
  @@map("contract_appendices")
}

model ContractAppendixItem {
  id                 String           @id @default(uuid())
  contractAppendixId String
  contractAppendix   ContractAppendix @relation(fields: [contractAppendixId], references: [id], onDelete: Cascade)
  position           Int
  sourceLineKey      String
  sku                String
  sellerSku          String?
  productName        String
  quantity           Int
  unit               String
  finalSellPrice     BigInt
  unitPriceBeforeVat BigInt
  vatRateBps         Int
  taxCode            String?
  taxLabel           String?
  taxSource          String
  taxFetchedAt       DateTime?
  lineBeforeVat      BigInt
  lineVatAmount      BigInt
  lineAfterVat       BigInt

  @@unique([contractAppendixId, position])
  @@index([contractAppendixId])
  @@index([sku])
  @@map("contract_appendix_items")
}
