# Copy to /srv/opshub-staging/env on mementoamoris. Replace every placeholder before deploy.
OPSHUB_STAGING=true
OPSHUB_STAGING_SANITIZE_CONFIRM=opshub-staging
COMPOSE_PROJECT_NAME=opshub_staging

OPSHUB_DOMAIN=opshub-staging.hoanghochoi.com
PUBLIC_BASE_URL=https://opshub-staging.hoanghochoi.com
OPSHUB_SSD_ROOT=/srv/opshub-staging
OPSHUB_BACKUP_ROOT=/srv/opshub-staging/backups
OPSHUB_HTTP_BIND=127.0.0.1:8090
OPSHUB_HTTPS_BIND=127.0.0.1:8443

POSTGRES_USER=opshub_staging_user
POSTGRES_PASSWORD=replace-with-long-random-staging-db-password
POSTGRES_DB=opshub_staging_db
DATABASE_URL=postgresql://opshub_staging_user:replace-with-long-random-staging-db-password@postgres:5432/opshub_staging_db

PORT=3000
NODE_ENV=production
JWT_SECRET=replace-with-long-random-staging-jwt-secret
EMAIL_DOMAIN_FILE=/opt/phongvu-opshub/data/email_domain.txt

# Prefer a sandbox mail service. Do not use the production Gmail/app password here.
# SMTP_HOST=smtp.mailtrap.io
# SMTP_PORT=2525
# SMTP_SECURE=false
# SMTP_USER=replace-with-staging-smtp-user
# SMTP_PASS=replace-with-staging-smtp-password
# SMTP_FROM=staging@hoanghochoi.com

REDIS_HOST=redis
REDIS_PORT=6379

DATA_SYNC_SOURCE=local
FIFO_DATE_TOLERANCE_DAYS=20
UPLOAD_BASE_DIR=/data/app_images
IMAGE_BASE_URL=https://opshub-staging.hoanghochoi.com/uploads
UPLOAD_MAX_BYTES=10485760
AVATAR_UPLOAD_MAX_BYTES=2097152
REQUEST_BODY_LIMIT=1mb

ALLOWED_ORIGINS=https://opshub-staging.hoanghochoi.com

# No production MAP, BigQuery, SMTP, or TTS secrets should be copied into staging.
PAYMENT_AUDIO_DIR=/data/payment-audio
PAYMENT_AUDIO_RETENTION_DAYS=7
APP_LOG_RETENTION_DAYS=30
MAP_TRANSACTION_RETENTION_DAYS=90
MAP_VIETIN_GLOBAL_SYNC_ENABLED=false
MAP_VIETIN_GLOBAL_SYNC_MAX_PAGES=1
TTS_VOICE_ID=piper:vi-vais1000
TTS_SPEED=0.90
TTS_PITCH=1.00
TTS_TIMEOUT_MS=20000

# Used only by npm run sanitize:staging during manual sanitized DB refresh.
STAGING_TEST_PASSWORD=replace-with-known-staging-test-password

APP_VERSION=staging
APP_BUILD_NUMBER=1
APP_MIN_SUPPORTED_BUILD=1
APP_UPDATE_URL=https://opshub.hoanghochoi.com/staging-download/downloads/phongvu-opshub-staging.apk
APP_RELEASE_NOTES=Staging baseline
APP_FORCE_UPDATE=false

APP_ANDROID_APP_VERSION=staging
APP_ANDROID_APP_BUILD_NUMBER=1
APP_ANDROID_APP_MIN_SUPPORTED_BUILD=1
APP_ANDROID_APP_UPDATE_URL=https://opshub.hoanghochoi.com/staging-download/downloads/phongvu-opshub-staging.apk
APP_ANDROID_APP_RELEASE_NOTES=Staging Android baseline
APP_ANDROID_APP_FORCE_UPDATE=false

APP_WINDOWS_APP_VERSION=staging
APP_WINDOWS_APP_BUILD_NUMBER=1
APP_WINDOWS_APP_MIN_SUPPORTED_BUILD=1
APP_WINDOWS_APP_UPDATE_URL=https://opshub.hoanghochoi.com/staging-download/downloads/phongvu-opshub-staging-windows-setup.exe
APP_WINDOWS_APP_RELEASE_NOTES=Staging Windows baseline
APP_WINDOWS_APP_FORCE_UPDATE=false

BACKUP_PRUNE=false
BACKUP_RETENTION_DAYS=14
