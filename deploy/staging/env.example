# Copy to /srv/opshub-staging/env on mementoamoris. Replace every placeholder before deploy.
OPSHUB_STAGING=true
OPSHUB_STAGING_SANITIZE_CONFIRM=opshub-staging
OPSHUB_STAGING_LOAD_MAINTENANCE_ENABLED=true
OPSHUB_STAGING_LOAD_OUTPUT_DIR=/srv/opshub-staging/load-output
COMPOSE_PROJECT_NAME=opshub_staging

OPSHUB_DOMAIN=opshub-staging.hoanghochoi.com
PUBLIC_BASE_URL=https://opshub-staging.hoanghochoi.com
OPSHUB_SSD_ROOT=/srv/opshub-staging
OPSHUB_BACKUP_ROOT=/srv/opshub-staging/backups
# Use a staging-only age recipient. Keep the private identity off this host.
BACKUP_AGE_RECIPIENT=replace-with-staging-age-public-recipient
BACKUP_ALLOW_UNENCRYPTED=false
DOCKER_LOG_MAX_SIZE=10m
DOCKER_LOG_MAX_FILE=5
OPSHUB_RUNTIME_UID=1000
OPSHUB_RUNTIME_GID=1000
OPSHUB_HTTP_BIND=127.0.0.1:8090
WS_ALLOW_LEGACY_JWT=false
REALTIME_LEGACY_JWT_SECRET=

POSTGRES_USER=opshub_staging_user
POSTGRES_PASSWORD=replace-with-long-random-staging-db-password
POSTGRES_DB=opshub_staging_db
DATABASE_URL=postgresql://opshub_staging_user:replace-with-long-random-staging-db-password@postgres:5432/opshub_staging_db

PORT=3000
NODE_ENV=production
JWT_SECRET=replace-with-long-random-staging-jwt-secret
EMAIL_DOMAIN_FILE=/opt/phongvu-opshub/data/email_domain.txt

# Prefer a sandbox mail service. Do not use the production Gmail/app password here.
# Leave every SMTP_* variable unset during release/load proof so temporary users
# can never trigger production mail delivery.
# SMTP_HOST=smtp.mailtrap.io
# SMTP_PORT=2525
# SMTP_SECURE=false
# SMTP_USER=replace-with-staging-smtp-user
# SMTP_PASS=replace-with-staging-smtp-password
# SMTP_FROM=staging@hoanghochoi.com

REDIS_HOST=redis
REDIS_PORT=6379
REDIS_USERNAME=
REDIS_PASSWORD=replace-with-long-random-staging-redis-password
REDIS_DB=0
REDIS_TLS=false

HOME_SUMMARY_PROJECTION_ENABLED=true
HOME_SUMMARY_PROJECTION_WORKER_ENABLED=true
HOME_SUMMARY_LEGACY_SYNC_FALLBACK_ENABLED=false
# Staging has no production ERP credentials; exercise checkpointed backfill only
# with an approved sandbox ERP configuration.
HOME_SUMMARY_ERP_BACKFILL_ENABLED=false
HOME_SUMMARY_ERP_BACKFILL_DAYS=90

# Staging release/load proof is read-only. These background jobs can mutate ERP
# caches or reconcile payment state, so the deploy workflow pins them off too.
ERP_ORDER_CACHE_SYNC_ENABLED=false
ERP_ORDER_STATUS_SYNC_ENABLED=false
VIETQR_AUTO_RECONCILE_ENABLED=false

DATA_SYNC_SOURCE=local
FIFO_DATE_TOLERANCE_DAYS=20
UPLOAD_BASE_DIR=/data/app_images
IMAGE_BASE_URL=https://opshub-staging.hoanghochoi.com/uploads
PRIVATE_MEDIA_BASE_DIR=/data/private-media
PRIVATE_MEDIA_PUBLIC_BASE_URL=https://opshub-staging.hoanghochoi.com/api
PRIVATE_UPLOAD_TEMP_DIR=/tmp/opshub-private-uploads
UPLOAD_AGGREGATE_MAX_BYTES=31457280
PRIVATE_MEDIA_MAX_PIXELS=24000000
UPLOAD_MAX_BYTES=10485760
AVATAR_UPLOAD_MAX_BYTES=2097152
REQUEST_BODY_LIMIT=1mb

ALLOWED_ORIGINS=https://opshub-staging.hoanghochoi.com
WS_MAX_CONNECTIONS_PER_USER=12

# No production MAP, BigQuery, SMTP, or TTS secrets should be copied into staging.
PAYMENT_AUDIO_DIR=/data/payment-audio
PAYMENT_AUDIO_RETENTION_DAYS=7
APP_LOG_RETENTION_DAYS=30
MAP_TRANSACTION_RETENTION_DAYS=90
MAP_VIETIN_GLOBAL_SYNC_ENABLED=false
MAP_VIETIN_GLOBAL_SYNC_MAX_PAGES=2
MAP_VIETIN_SYNC_DELAY_MIN_MS=1000
MAP_VIETIN_SYNC_DELAY_MAX_MS=2000
MAP_VIETIN_DEEP_SWEEP_DELAY_MIN_MS=30000
MAP_VIETIN_DEEP_SWEEP_DELAY_MAX_MS=60000
MAP_VIETIN_RATE_LIMIT_BACKOFF_BASE_MS=30000
MAP_VIETIN_RATE_LIMIT_BACKOFF_MAX_MS=120000
MAP_VIETIN_FORBIDDEN_BACKOFF_MS=300000
MAP_VIETIN_SYNC_FINGERPRINT_CACHE_TTL_MS=300000
MAP_VIETIN_SYNC_FINGERPRINT_CACHE_MAX_ENTRIES=20000
BANK_PROVIDER_TIMEOUT_MS=30000
BANK_PROVIDER_RESPONSE_MAX_BYTES=10485760
TTS_VOICE_ID=piper:vi-vais1000
TTS_SPEED=0.90
TTS_PITCH=1.00
TTS_TIMEOUT_MS=20000
TTS_RESPONSE_MAX_BYTES=20971520
PAYMENT_TTS_CONCURRENCY=2
PAYMENT_SPEAKER_STREAMING_ENABLED=false
PAYMENT_STREAM_EVENT_REPEAT_COUNT=3
PAYMENT_STREAM_EVENT_REPEAT_GAP_MS=1000
PAYMENT_STREAM_PENDING_RECOVERY_WINDOW_SECONDS=30
# Optional trial: TTS only the dynamic amount and join a fixed prefix WAV at playback.
PAYMENT_TTS_AUDIO_MODE=amount_only_with_prefix
PAYMENT_PREFIX_WAV_PATH=/data/import/payment-prefix.wav
PAYMENT_CUE_PREFIX_WAV_PATH=/data/import/payment-cue-prefix.wav
PAYMENT_AMOUNT_AUDIO_CACHE_RETENTION_DAYS=90

# Used only by npm run sanitize:staging during manual sanitized DB refresh.
STAGING_TEST_PASSWORD=replace-with-known-staging-test-password

APP_VERSION=staging
APP_BUILD_NUMBER=1
APP_MIN_SUPPORTED_BUILD=1
APP_UPDATE_URL=https://opshub-staging.hoanghochoi.com/downloads/phongvu-opshub-staging.apk
APP_PACKAGE_URL=https://opshub-staging.hoanghochoi.com/downloads/phongvu-opshub-staging.apk
APP_PACKAGE_SHA256=
APP_PACKAGE_SIZE_BYTES=0
APP_PACKAGE_TYPE=apk
APP_RELEASE_NOTES=Staging baseline
APP_FORCE_UPDATE=false

APP_ANDROID_APP_VERSION=staging
APP_ANDROID_APP_BUILD_NUMBER=1
APP_ANDROID_APP_MIN_SUPPORTED_BUILD=1
APP_ANDROID_APP_UPDATE_URL=https://opshub-staging.hoanghochoi.com/downloads/phongvu-opshub-staging.apk
APP_ANDROID_APP_PACKAGE_URL=https://opshub-staging.hoanghochoi.com/downloads/phongvu-opshub-staging.apk
APP_ANDROID_APP_PACKAGE_SHA256=
APP_ANDROID_APP_PACKAGE_SIZE_BYTES=0
APP_ANDROID_APP_PACKAGE_TYPE=apk
APP_ANDROID_APP_RELEASE_NOTES=Staging Android baseline
APP_ANDROID_APP_FORCE_UPDATE=false

APP_WINDOWS_APP_VERSION=staging
APP_WINDOWS_APP_BUILD_NUMBER=1
APP_WINDOWS_APP_MIN_SUPPORTED_BUILD=1
APP_WINDOWS_APP_UPDATE_URL=https://opshub-staging.hoanghochoi.com/downloads/phongvu-opshub-staging-windows-setup.exe
APP_WINDOWS_APP_PACKAGE_URL=https://opshub-staging.hoanghochoi.com/downloads/phongvu-opshub-staging-windows-setup.exe
APP_WINDOWS_APP_PACKAGE_SHA256=
APP_WINDOWS_APP_PACKAGE_SIZE_BYTES=0
APP_WINDOWS_APP_PACKAGE_TYPE=windowsInstaller
APP_WINDOWS_APP_INSTALLER_ARGS=/VERYSILENT,/SUPPRESSMSGBOXES,/NORESTART,/CLOSEAPPLICATIONS,/OPSHUBRELAUNCH=1
APP_WINDOWS_APP_RELEASE_NOTES=Staging Windows baseline
APP_WINDOWS_APP_FORCE_UPDATE=false

BACKUP_PRUNE=false
BACKUP_RETENTION_DAYS=14
