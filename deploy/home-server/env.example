# Copy to deploy/home-server/env on the home server.
# Keep runtime data on SSD. Point backup script to a TrueNAS-mounted path.
OPSHUB_DOMAIN=opshub.example.com
PUBLIC_BASE_URL=https://opshub.example.com
OPSHUB_SSD_ROOT=/srv/opshub
OPSHUB_BACKUP_ROOT=/mnt/truenas/opshub-backups
# On an existing VPS with host Nginx/Cloudflare Tunnel, bind Caddy to localhost
# and point the tunnel at http://127.0.0.1:8090.
# OPSHUB_HTTP_BIND=127.0.0.1:8090
# OPSHUB_HTTPS_BIND=127.0.0.1:8443

POSTGRES_USER=opshub_user
POSTGRES_PASSWORD=replace-with-long-random-db-password
POSTGRES_DB=opshub_db
DATABASE_URL=postgresql://opshub_user:replace-with-long-random-db-password@postgres:5432/opshub_db

PORT=3000
NODE_ENV=production
JWT_SECRET=replace-with-long-random-jwt-secret
EMAIL_DOMAIN_FILE=/opt/phongvu-opshub/data/email_domain.txt

# Email verification for account registration.
# For Gmail, use an app password, not the account login password.
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=your-email@example.com
SMTP_PASS=replace-with-mail-app-password
SMTP_FROM=your-email@example.com

REDIS_HOST=redis
REDIS_PORT=6379

# Payment notification audio.
# TTS_SERVICE_URL should point to an internal VieNeu-TTS sidecar when enabled.
PAYMENT_AUDIO_DIR=/data/payment-audio
PAYMENT_AUDIO_RETENTION_DAYS=7
APP_LOG_RETENTION_DAYS=30
MAP_TRANSACTION_RETENTION_DAYS=90
# TTS_SERVICE_URL=http://vieneu-tts:8000
TTS_TIMEOUT_MS=20000

DATA_SYNC_SOURCE=local
# Keep service-account JSON outside the app repo; /data/import is mounted read-only.
# BIGQUERY_KEY_FILE=/data/import/bigquery-service-account.json
UPLOAD_BASE_DIR=/data/app_images
IMAGE_BASE_URL=https://opshub.example.com/uploads
UPLOAD_MAX_BYTES=5242880
REQUEST_BODY_LIMIT=1mb

ALLOWED_ORIGINS=https://opshub.example.com

APP_VERSION=1.1.1
APP_BUILD_NUMBER=2
APP_MIN_SUPPORTED_BUILD=2
APP_UPDATE_URL=https://opshub.example.com/downloads/phongvu-opshub.apk
APP_RELEASE_NOTES=Initial VPS release
APP_FORCE_UPDATE=false

APP_ANDROID_APP_VERSION=1.1.1
APP_ANDROID_APP_BUILD_NUMBER=2
APP_ANDROID_APP_MIN_SUPPORTED_BUILD=2
APP_ANDROID_APP_UPDATE_URL=https://opshub.example.com/downloads/phongvu-opshub.apk
APP_ANDROID_APP_RELEASE_NOTES=Initial Android release
APP_ANDROID_APP_FORCE_UPDATE=false

APP_WINDOWS_APP_VERSION=1.1.1
APP_WINDOWS_APP_BUILD_NUMBER=2
APP_WINDOWS_APP_MIN_SUPPORTED_BUILD=2
APP_WINDOWS_APP_UPDATE_URL=https://opshub.example.com/downloads/phongvu-opshub-windows.zip
APP_WINDOWS_APP_RELEASE_NOTES=Initial Windows release
APP_WINDOWS_APP_FORCE_UPDATE=false

BACKUP_PRUNE=false
BACKUP_RETENTION_DAYS=30
