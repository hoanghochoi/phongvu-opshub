http://{$OPSHUB_DOMAIN} {
  encode gzip zstd

  # Cloudflare Tunnel terminates TLS before forwarding to this HTTP origin.
  # Redirect only requests that Cloudflare marked as originally HTTP; an
  # unconditional origin redirect would loop for HTTPS visitors.
  @insecure_edge_request header X-Forwarded-Proto http
  redir @insecure_edge_request https://{host}{uri} 308

  header {
    -Server
    X-Content-Type-Options "nosniff"
    Referrer-Policy "no-referrer"
    X-Frame-Options "SAMEORIGIN"
    Strict-Transport-Security "max-age=31536000; includeSubDomains"
    Permissions-Policy "camera=(self), clipboard-read=(self), clipboard-write=(self), fullscreen=(self), geolocation=(), microphone=(), payment=(), usb=()"
    # Enforced after staging Home/Help/Download and WebSocket report-only smoke
    # completed without CSP violations. Keep unsafe-eval/wasm allowances until
    # the Flutter web renderer no longer requires them.
    Content-Security-Policy "default-src 'self'; base-uri 'self'; object-src 'none'; frame-ancestors 'self'; form-action 'self'; script-src 'self' 'unsafe-inline' 'unsafe-eval' 'wasm-unsafe-eval' blob:; style-src 'self' 'unsafe-inline'; img-src 'self' data: blob: https:; font-src 'self' data:; connect-src 'self' https: wss:; worker-src 'self' blob:; child-src 'self' blob:; manifest-src 'self'; media-src 'self' data: blob:"
  }

  handle_path /api/* {
    reverse_proxy api:3000
  }

  handle /ws* {
    reverse_proxy realtime:8080
  }

  handle /reset-password* {
    reverse_proxy api:3000
  }

  handle /download/ {
    redir /download 308
  }

  handle /download {
    root * /srv/downloads
    rewrite * /download.html
    file_server
  }

  handle /help/ {
    redir /help 308
  }

  handle_path /help/assets/* {
    root * /srv/downloads/help/assets
    file_server
  }

  header /help Cache-Control "no-store, no-cache, must-revalidate"

  handle /staging-download/ {
    redir https://opshub-staging.hoanghochoi.com/download 302
  }

  handle /staging-download {
    redir https://opshub-staging.hoanghochoi.com/download 302
  }

  handle_path /staging-download/* {
    redir https://opshub-staging.hoanghochoi.com/download 302
  }

  handle_path /uploads/* {
    root * /srv/uploads
    file_server
  }

  header /downloads/latest.json Cache-Control "no-store, no-cache, must-revalidate"

  handle_path /downloads/* {
    root * /srv/downloads
    file_server
  }

  handle /health {
    respond "ok" 200
  }

  header /flutter_service_worker.js Cache-Control "no-store, no-cache, must-revalidate"
  header /version.json Cache-Control "no-store, no-cache, must-revalidate"
  header / Cache-Control "no-store, no-cache, must-revalidate"
  header /index.html Cache-Control "no-store, no-cache, must-revalidate"
  header /main.dart.js Cache-Control "no-store, no-cache, must-revalidate"
  header /flutter_bootstrap.js Cache-Control "no-store, no-cache, must-revalidate"
  header /flutter.js Cache-Control "no-store, no-cache, must-revalidate"
  header /manifest.json Cache-Control "no-store, no-cache, must-revalidate"

  handle {
    root * /srv/web
    try_files {path} /index.html
    file_server
  }
}
