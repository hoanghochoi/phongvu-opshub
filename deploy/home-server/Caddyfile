{$OPSHUB_DOMAIN} {
  encode gzip zstd

  handle_path /api/* {
    reverse_proxy api:3000
  }

  handle /ws* {
    reverse_proxy realtime:8080
  }

  handle_path /uploads/* {
    root * /srv/uploads
    file_server
  }

  handle_path /downloads/* {
    root * /srv/downloads
    file_server
  }

  respond /health "ok" 200
}
